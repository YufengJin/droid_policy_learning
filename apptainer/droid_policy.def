Bootstrap: docker
From: nvidia/cuda:11.8.0-cudnn8-devel-ubuntu20.04

# 与 docker/Dockerfile 对齐：INCLUDE_ROBOCASA=1 时安装 RoboCasa 系统库、robosuite、uv sync --extra robocasa
# 构建：apptainer build droid_policy.sif apptainer/droid_policy.def
# 无特权：apptainer build --fakeroot droid_policy.sif apptainer/droid_policy.def
# RoboCasa：apptainer build --build-arg INCLUDE_ROBOCASA=1 droid_policy_robocasa.sif apptainer/droid_policy.def
%arguments
    INCLUDE_ROBOCASA=0

%labels
    Author Droid_Dev
    Version 2.0
    Description Droid Policy Learning (uv + pyproject, aligned with docker/Dockerfile)

# 在仓库根目录执行 apptainer build（路径相对于当前工作目录）
%files
    pyproject.toml /build/pyproject.toml
    uv.lock /build/uv.lock
    docker/entrypoint.sh /usr/local/bin/entrypoint.sh

%environment
    export DEBIAN_FRONTEND=noninteractive
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8
    export PATH="/opt/venv/bin:/usr/local/bin:/root/.local/bin:/usr/bin:/bin"
    export VIRTUAL_ENV="/opt/venv"
    export HOME=/root
    export HF_HOME=/root/.cache/huggingface

%post
    export DEBIAN_FRONTEND=noninteractive
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

    INCLUDE_ROBOCASA="{{ INCLUDE_ROBOCASA }}"

    # 1. System dependencies（与 docker/Dockerfile 一致）
    apt-get update -y
    apt-get install -y \
        curl wget tar procps bzip2 ca-certificates git build-essential cmake unzip \
        ffmpeg libgl1-mesa-glx libglib2.0-0
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    if [ "${INCLUDE_ROBOCASA}" = "1" ]; then
        apt-get update -y
        apt-get install -y --no-install-recommends \
            libx11-6 libxext6 libxrender1 libsm6 libegl1 libosmesa6 libhidapi-libusb0 \
            lsof psmisc
        apt-get clean
        rm -rf /var/lib/apt/lists/*
    fi

    # 2. uv（与 docker/Dockerfile 一致）
    curl -LsSf https://astral.sh/uv/install.sh | sh
    export PATH="/root/.local/bin:${PATH}"
    # 与 Dockerfile 一致：bind /root 时不能依赖 /root/.local/bin/uv
    cp /root/.local/bin/uv /usr/local/bin/uv && chmod +x /usr/local/bin/uv

    # 3. Python venv
    uv venv --python 3.10 /opt/venv
    export PATH="/opt/venv/bin:${PATH}"
    export VIRTUAL_ENV="/opt/venv"
    # uv 把 Python 解释器装在 /root/.local/share/uv/python/...
    # Apptainer 运行时常把宿主机目录 bind 到 /root，导致软链接失效。
    # 把解释器复制到 /opt/python310 并重链 venv，彻底脱离 /root 依赖。
    _uv_py=$(find /root/.local/share/uv/python -maxdepth 3 -name 'python3.10' -type f 2>/dev/null | head -1)
    if [ -n "$_uv_py" ]; then
        _uv_dir=$(dirname "$(dirname "$_uv_py")")
        cp -a "$_uv_dir" /opt/python310
        ln -sf /opt/python310/bin/python3.10 /opt/venv/bin/python
        ln -sf /opt/python310/bin/python3.10 /opt/venv/bin/python3
        ln -sf /opt/python310/bin/python3.10 /opt/venv/bin/python3.10
    fi

    # 4. Octo（与 docker/Dockerfile 一致）
    mkdir -p /opt/third_party
    cd /opt/third_party
    git clone https://github.com/octo-models/octo.git
    cd octo && git checkout 85b83fc19657ab407a7f56558a5384ae56fe453b

    # 5. Robosuite（仅 INCLUDE_ROBOCASA=1）
    if [ "${INCLUDE_ROBOCASA}" = "1" ]; then
        cd /opt/third_party
        git clone https://github.com/ARISE-Initiative/robosuite.git robosuite
        cd robosuite && git checkout v1.5.2
        uv pip install -e .
    fi

    # 6. 锁定依赖栈（uv sync，与 docker/Dockerfile 一致）
    cd /build
    if [ "${INCLUDE_ROBOCASA}" = "1" ]; then
        CMAKE_POLICY_VERSION_MINIMUM=3.5 uv sync --frozen --no-install-project --active --extra robocasa
    else
        CMAKE_POLICY_VERSION_MINIMUM=3.5 uv sync --frozen --no-install-project --active
    fi

    # 7. Octo editable
    uv pip install -e /opt/third_party/octo

    # 8. 运行时与 Docker 一致：entrypoint 负责 uv pip install -e 项目（及 RoboCasa 资产）
    chmod +x /usr/local/bin/entrypoint.sh

    # 9. 挂载占位目录
    mkdir -p /workspace/droid_policy_learning
    mkdir -p /workspace/datasets/droid
    mkdir -p /workspace/datasets/robocasa
    mkdir -p /workspace/datasets/libero
    mkdir -p /root/.cache/huggingface

    # 与 docker/entrypoint.sh 中 INCLUDE_ROBOCASA 判断一致
    echo "${INCLUDE_ROBOCASA}" > /etc/droid_policy_include_robocasa
    printf 'export INCLUDE_ROBOCASA="%s"\n' "${INCLUDE_ROBOCASA}" > /etc/profile.d/99-droid-policy-robocasa-flag.sh

%runscript
    export PATH="/opt/venv/bin:/usr/local/bin:/root/.local/bin:${PATH:-/usr/bin:/bin}"
    export VIRTUAL_ENV="/opt/venv"
    if [ -f /etc/droid_policy_include_robocasa ]; then
        export INCLUDE_ROBOCASA="$(tr -d '\n' < /etc/droid_policy_include_robocasa)"
    fi
    if [ "$#" -eq 0 ]; then
        set -- /bin/bash
    fi
    exec /usr/local/bin/entrypoint.sh "$@"

%help
    与 docker/Dockerfile 对齐：uv + pyproject.toml + uv.lock；入口为 docker/entrypoint.sh。
    详见 apptainer/README.md。基础构建：apptainer build [--fakeroot] droid_policy.sif apptainer/droid_policy.def
